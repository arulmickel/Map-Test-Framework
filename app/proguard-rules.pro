# Proguard rules for release builds. isMinifyEnabled is false in this project,
# so these rules are inert today — but the file must exist because the release
# build type references it.
#
# When you turn on minification later, add keep rules here. Common starters:
#
# -keepattributes Signature, *Annotation*
# -keep class com.maptest.data.remote.** { *; }   # Retrofit/Gson models
# -keep class com.maptest.domain.model.** { *; }
